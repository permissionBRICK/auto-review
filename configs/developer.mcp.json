{
  "mcpServers": {
    "auto-review": {
      "command": "npx",
      "args": [
        "-y",
        "@permissionbrick/auto-review-mcp",
        "--role",
        "developer"
      ],
      "env": {
        "AUTO_REVIEW_POLL_SECONDS": "240",
        "AUTO_REVIEW_WAIT_SECONDS": "600"
      },
      "timeout": 1800000
    }
  }
}
